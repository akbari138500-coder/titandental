datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  ADMIN
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  COMPREHENSIVE
}

enum ImageType {
  CLINICAL
  RADIOGRAPH
  LAB
}

enum QuestionType {
  MCQ
  SPOT
  SEQUENCING
  MATCHING
  FREE_TEXT
}

model User {
  id                String             @id @default(uuid())
  name              String
  email             String             @unique
  passwordHash      String
  role              Role               @default(STUDENT)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attempts          Attempt[]
  studyProgress     StudyProgress[]
  spacedRepetitions SpacedRepetition[]
  chatMessages      ChatMessage[]

  @@index([email])
}

model Subject {
  id            String          @id @default(uuid())
  name          String
  slug          String          @unique
  description   String?
  published     Boolean         @default(true)
  cases         Case[]
  studyProgress StudyProgress[]
}

model Case {
  id                String             @id @default(uuid())
  title             String
  slug              String             @unique
  subjectId         String
  subject           Subject            @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chiefComplaint    String
  demographic       String
  hpi               String
  medicalHistory    String?
  examNotes         String
  difficulty        Difficulty         @default(BEGINNER)
  published         Boolean            @default(true)
  referencePlan     String
  referenceRubric   Json
  scientificSource  String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  images            CaseImage[]
  diagnosticTests   DiagnosticTest[]
  attempts          Attempt[]
  questions         Question[]
  spacedRepetitions SpacedRepetition[]
  chatMessages      ChatMessage[]

  @@index([subjectId])
  @@index([slug])
}

model CaseImage {
  id            String    @id @default(uuid())
  caseId        String
  case          Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  url           String
  caption       String?
  type          ImageType @default(RADIOGRAPH)
  licenseSource String?
  createdAt     DateTime  @default(now())

  @@index([caseId])
}

model DiagnosticTest {
  id           String   @id @default(uuid())
  caseId       String
  case         Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  name         String
  result       String
  isNecessary  Boolean  @default(false)
  costWeight   Float    @default(0.0)
  createdAt    DateTime @default(now())

  @@index([caseId])
}

model Attempt {
  id                     String    @id @default(uuid())
  userId                 String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId                 String
  case                   Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  finalScore             Float
  matchedItems           Json
  missedItems            Json
  incorrectItems         Json
  feedback               String
  safetyFlag             Boolean   @default(false)
  treatmentPlanSubmitted String
  completedAt            DateTime  @default(now())

  @@index([userId])
  @@index([caseId])
}

model Question {
  id            String       @id @default(uuid())
  caseId        String
  case          Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type          QuestionType @default(MCQ)
  text          String
  options       Json
  correctAnswer Json
  explanation   String
  createdAt     DateTime     @default(now())

  @@index([caseId])
}

model StudyProgress {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  mastery       Float    @default(0.0)
  heatMapData   Json
  lastStudiedAt DateTime @default(now())

  @@unique([userId, subjectId])
}

model SpacedRepetition {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId       String
  case         Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  nextReviewAt DateTime @default(now())
  interval     Float    @default(1.0)
  easeFactor   Float    @default(2.5)
  repetitions  Int      @default(0)

  @@unique([userId, caseId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId    String?
  case      Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  role      String
  text      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([caseId])
}
